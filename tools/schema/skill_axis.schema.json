{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "immediate_end_skills": {
      "type": "array",
      "items": {"type": "integer"}
    },
    "main_axis": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": ["skill", "end_skill"]
          },
          "op": {
            "type": "integer",
            "minimum": 1,
            "maximum": 4
          }
        },
        "required": ["type", "op"]
      }
    }
  },
  "required": ["immediate_end_skills", "main_axis"]
}
